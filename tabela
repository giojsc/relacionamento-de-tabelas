CREATE TABLE usuarios (
  id   bigint generated always as identity primary key,
  nome text NOT NULL
);

-- UNIQUE na FK é o que garante o 1:1
CREATE TABLE perfis (
  id         bigint generated always as identity primary key,
  bio        text,
  usuario_id bigint UNIQUE,
  CONSTRAINT fk_usuario
    FOREIGN KEY (usuario_id)
    REFERENCES usuarios(id)
);

INSERT INTO usuarios (nome) VALUES ('Alice'), ('Bob');

INSERT INTO perfis (bio, usuario_id) VALUES
  ('Dev front-end', 1),
  ('Designer',      2);

SELECT u.nome, p.bio
FROM  usuarios u
JOIN  perfis   p ON p.usuario_id = u.id;
CREATE TABLE turmas (
  id   bigint generated always as identity primary key,
  nome text NOT NULL
);

-- Sem UNIQUE: vários alunos podem ter a mesma turma_id
CREATE TABLE alunos_turma (
  id       bigint generated always as identity primary key,
  nome     text NOT NULL,
  turma_id bigint,
  CONSTRAINT fk_turma
    FOREIGN KEY (turma_id)
    REFERENCES turmas(id)
);

INSERT INTO turmas (nome) VALUES ('DS1'), ('DS2');

INSERT INTO alunos_turma (nome, turma_id) VALUES
  ('João',  1),
  ('Maria', 1),
  ('Ana',   2);

SELECT a.nome, t.nome AS turma
FROM  alunos_turma a
JOIN  turmas       t ON a.turma_id = t.id;
CREATE TABLE alunos_disc (
  id   bigint generated always as identity primary key,
  nome text NOT NULL
);

CREATE TABLE disciplinas (
  id   bigint generated always as identity primary key,
  nome text NOT NULL
);

-- Tabela intermediária: cada linha = uma associação
-- PK composta evita matrícula duplicada
CREATE TABLE matriculas (
  aluno_id      bigint REFERENCES alunos_disc(id),
  disciplina_id bigint REFERENCES disciplinas(id),
  PRIMARY KEY (aluno_id, disciplina_id)
);

INSERT INTO alunos_disc (nome) VALUES ('João'), ('Maria'), ('Ana');
INSERT INTO disciplinas (nome) VALUES ('Banco de Dados'), ('Back-End'), ('Redes');

INSERT INTO matriculas (aluno_id, disciplina_id) VALUES
  (1, 1), -- João  → Banco de Dados
  (1, 2), -- João  → Back-End
  (2, 1), -- Maria → Banco de Dados
  (3, 3); -- Ana   → Redes

SELECT a.nome AS aluno, d.nome AS disciplina
FROM  matriculas   m
JOIN  alunos_disc  a ON m.aluno_id      = a.id
JOIN  disciplinas  d ON m.disciplina_id = d.id
ORDER BY a.nome;
